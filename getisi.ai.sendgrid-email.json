{
  "providerId": "getisi.ai",
  "providerName": "Isi.ai",
  "serviceId": "sendgrid-email",
  "serviceName": "Isi.ai Email Authentication",
  "version": 2,
  "logoUrl": "https://app.getisi.ai/logo-icon.png",
  "description": "Configures DKIM authentication, email tracking, SPF, and DMARC records for email delivery via SendGrid.",
  "syncBlock": false,
  "syncPubKeyDomain": "domainconnect.getisi.ai",
  "syncRedirectDomain": "getisi.ai",
  "shared": false,
  "hostRequired": false,
  "records": [
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim1Host%",
      "pointsTo": "%dkim1Value%",
      "ttl": 3600
    },
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim2Host%",
      "pointsTo": "%dkim2Value%",
      "ttl": 3600
    },
    {
      "groupId": "tracking",
      "type": "CNAME",
      "host": "%trackHost%",
      "pointsTo": "%trackValue%",
      "ttl": 3600
    },
    {
      "groupId": "spf",
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:sendgrid.net",
      "ttl": 3600
    },
    {
      "groupId": "dmarc",
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=none; sp=none;",
      "ttl": 3600,
      "txtConflictMatchingMode": "All",
      "essential": "OnApply"
    }
  ]
}
