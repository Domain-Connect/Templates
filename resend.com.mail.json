{
	"providerId": "resend.com",
	"providerName": "Resend",
	"serviceId": "mail",
	"serviceName": "Mail",
	"version": 5,
	"syncPubKeyDomain": "resend.com",
	"syncRedirectDomain": "resend.com",
	"description": "Enable email signing and specify authorized senders.",
	"logoUrl": "https://resend.com/static/brand/resend-wordmark-black.svg",
	"records": [
		{
			"groupId": "outbound",
			"type": "MX",
			"host": "%spfDomain%",
			"pointsTo": "feedback-smtp.%region%.amazonses.com",
			"ttl": 3600,
			"priority": 10
		},
		{
			"groupId": "outbound",
			"type": "SPFM",
			"host": "%spfDomain%",
			"ttl": 3600,
			"spfRules": "include:amazonses.com"
		},
		{
			"groupId": "dkim",
			"type": "TXT",
			"host": "resend._domainkey",
			"ttl": 3600,
			"data": "p=%domainKey%"
		},
		{
			"groupId": "click-tracking",
			"type": "CNAME",
			"host": "%clickTrackingSubdomain%",
			"pointsTo": "%clickTrackingCnameTarget%.resend-dns.com",
			"ttl": 3600
		}
	]
}
