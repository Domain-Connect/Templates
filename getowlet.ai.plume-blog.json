  "version": 2,
  "logoUrl": "https://plume.getowlet.ai/images/logo-mark.png",
  "description": "Point a custom subdomain at your Plume blog. Adds a CNAME record so readers can reach your blog at your own domain (e.g. blog.yourcompany.com).",
