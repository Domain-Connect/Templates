  "syncPubKeyDomain": "plume.getowlet.ai",
  "hostRequired": true,
  "records": [
    {
      "type": "CNAME",
      "host": "@",
      "pointsTo": "plume.getowlet.ai",
      "ttl": 3600
    }
  ]
}
