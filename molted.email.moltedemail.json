{
  "providerId": "molted.email",
  "providerName": "Molted Email",
  "serviceId": "moltedemail",
  "serviceName": "Molted Email Authentication",
  "version": 2,
  "logoUrl": "https://molted.email/logo.svg",
  "description": "Configures SPF, DKIM, DMARC and MX records for sending and receiving email via Molted Email",
  "variableDescription": "dkimSelector1: DKIM selector (e.g. resend). dkimValue1: DKIM public key. mxSend: region-specific outbound feedback MX (e.g. feedback-smtp.eu-west-1.amazonses.com). mxInbound: region-specific inbound MX (e.g. inbound-smtp.eu-west-1.amazonaws.com). spfInclude: SPF include domain (e.g. amazonses.com).",
  "syncBlock": false,
  "syncPubKeyDomain": "molted.email",
  "syncRedirectDomain": "molted.email",
  "warnPhishing": true,
  "hostRequired": false,
  "records": [
    {
      "type": "TXT",
      "host": "%dkimSelector1%._domainkey",
      "data": "%dkimValue1%",
      "ttl": 3600
    },
    {
      "type": "MX",
      "host": "send",
      "pointsTo": "%mxSend%",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "SPFM",
      "host": "send",
      "spfRules": "include:%spfInclude%"
    },
    {
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=none;",
      "ttl": 3600,
      "txtConflictMatchingMode": "All"
    },
    {
      "type": "MX",
      "host": "@",
      "pointsTo": "%mxInbound%",
      "priority": 10,
      "ttl": 3600
    }
  ]
}
