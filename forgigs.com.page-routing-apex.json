{
    "providerId": "forgigs.com",
    "providerName": "Forgigs",
    "serviceId": "page-routing-apex",
    "serviceName": "Connect your domain to Forgigs",
    "version": 1,
    "logoUrl": "https://pages.forgigs.com/logo.svg",
    "description": "Points your apex domain (e.g. example.com) to your Forgigs page by creating an A record.",
    "variableDescription": "%vercel_ip%: Forgigs server IP address",
    "syncPubKeyDomain": "keys.forgigs.com",
    "syncRedirectDomain": "pages.forgigs.com",
    "records": [
        {
            "type": "A",
            "host": "@",
            "pointsTo": "%vercel_ip%",
            "ttl": 3600
        }
    ]
}
