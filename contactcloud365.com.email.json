{
  "providerId": "contactcloud365.com",
  "providerName": "AlphaOutreach",
  "serviceId": "email",
  "serviceName": "AlphaOutreach Email Sending",
  "version": 1,
  "logoUrl": "https://outreach.contactcloud365.com/logo.png",
  "description": "Authenticate your domain to send email through AlphaOutreach (DKIM + SPF).",
  "syncPubKeyDomain": "contactcloud365.com",
  "syncRedirectDomain": "contactcloud365.com",
  "syncBlock": false,
  "records": [
    {
      "groupId": "dkim",
      "type": "TXT",
      "host": "%dkimselector%._domainkey",
      "data": "v=DKIM1; k=rsa; p=%dkimkey%",
      "ttl": 3600
    },
    {
      "groupId": "spf",
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:contactcloud365.com",
      "ttl": 3600
    }
  ]
}
