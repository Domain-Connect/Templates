{
  "providerId": "sixuse.com",
  "providerName": "Sixuse",
  "serviceId": "mail",
  "serviceName": "Sixuse Custom Domain Mail",
  "version": 2,
  "description": "Configures DNS records so a domain can receive mail through Sixuse project identities and authenticate outbound replies with SPF, DKIM, and DMARC.",
  "syncBlock": false,
  "syncRedirectDomain": "sixuse.com",
  "warnPhishing": true,
  "variableDescription": "%verificationToken%: Sixuse domain ownership verification token; %dkimSelector%: DKIM selector generated by Sixuse; %dkimPublicKey%: DKIM RSA public key generated by Sixuse.",
  "records": [
    {
      "type": "TXT",
      "host": "_sixuse",
      "data": "sixuse-domain-verification=%verificationToken%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "sixuse-domain-verification="
    },
    {
      "type": "MX",
      "host": "@",
      "pointsTo": "mx1.sixuse.com",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:sixuse.com",
      "ttl": 3600
    },
    {
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=none; rua=mailto:dmarc@sixuse.com",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DMARC1"
    },
    {
      "type": "TXT",
      "host": "%dkimSelector%._domainkey",
      "data": "v=DKIM1; k=rsa; p=%dkimPublicKey%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DKIM1"
    }
  ]
}
