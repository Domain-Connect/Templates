{
    "providerId": "forgigs.com",
    "providerName": "Forgigs",
    "serviceId": "page-setup-subdomain",
    "serviceName": "Forgigs Page DNS Setup",
    "version": 1,
    "logoUrl": "https://app.forgigs.com/logo.png",
    "description": "Configure your subdomain to work with Forgigs (page routing + email sending)",
    "variableDescription": "%subdomain_host%: Subdomain label; %vercel_cname%: Vercel CNAME target; %spf_value%: SPF include value; %dkim1_host%/%dkim1_value%: DKIM record 1; %dkim2_host%/%dkim2_value%: DKIM record 2",
    "syncPubKeyDomain": "keys.forgigs.com",
    "syncRedirectDomain": "app.forgigs.com",
    "records": [
        {
            "type": "CNAME",
            "host": "%subdomain_host%",
            "pointsTo": "%vercel_cname%",
            "ttl": 3600
        },
        {
            "type": "SPFM",
            "host": "@",
            "spfRules": "%spf_value%",
            "ttl": 3600
        },
        {
            "type": "CNAME",
            "host": "%dkim1_host%",
            "pointsTo": "%dkim1_value%",
            "ttl": 3600
        },
        {
            "type": "CNAME",
            "host": "%dkim2_host%",
            "pointsTo": "%dkim2_value%",
            "ttl": 3600
        },
        {
            "type": "CNAME",
            "host": "%dkim3_host%",
            "pointsTo": "%dkim3_value%",
            "ttl": 3600
        }
    ]
}
