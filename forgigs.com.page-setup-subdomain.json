{
    "providerId": "forgigs.com",
    "providerName": "Forgigs",
    "serviceId": "page-setup-subdomain",
    "serviceName": "Connect your subdomain to Forgigs",
    "version": 1,
    "logoUrl": "https://app.forgigs.com/logo.svg",
    "description": "Points your subdomain (e.g. www.yourdomain.com) to your Forgigs page by creating a CNAME record. Use the companion email setup template to also configure email sending.",
    "variableDescription": "%vercel_cname%: Forgigs CNAME target address",
    "syncPubKeyDomain": "keys.forgigs.com",
    "syncRedirectDomain": "app.forgigs.com",
    "hostRequired": true,
    "records": [
        {
            "type": "CNAME",
            "host": "@",
            "pointsTo": "%vercel_cname%",
            "ttl": 3600
        }
    ]
}
