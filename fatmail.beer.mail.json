{
  "providerId": "fatmail.beer",
  "providerName": "FatMail",
  "serviceId": "mail",
  "serviceName": "FatMail Email",
  "version": 1,
  "logoUrl": "https://fatmail.beer/icon-512.png",
  "description": "Sets up MX, SPF, DKIM, DMARC and mail client auto-configuration records for FatMail hosted email.",
  "variableDescription": "mailhost is the FatMail mail server hostname, dkimselector and dkim are the DKIM selector and public key TXT value generated by the mail server.",
  "syncBlock": false,
  "syncPubKeyDomain": "fatmail.beer",
  "syncRedirectDomain": "fatmail.beer",
  "records": [
    {
      "type": "MX",
      "host": "@",
      "pointsTo": "%mailhost%",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "SPFM",
      "host": "@",
      "spfRules": "mx"
    },
    {
      "type": "TXT",
      "host": "%dkimselector%._domainkey",
      "data": "%dkim%",
      "ttl": 3600,
      "txtConflictMatchingMode": "All"
    },
    {
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=quarantine; rua=mailto:postmaster@%domain%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DMARC1",
      "essential": "OnApply"
    },
    {
      "type": "CNAME",
      "host": "autodiscover",
      "pointsTo": "%mailhost%",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "autoconfig",
      "pointsTo": "%mailhost%",
      "ttl": 3600
    },
    {
      "type": "SRV",
      "name": "@",
      "service": "_autodiscover",
      "protocol": "_tcp",
      "priority": 0,
      "weight": 1,
      "port": 443,
      "target": "%mailhost%",
      "ttl": 3600
    },
    {
      "type": "SRV",
      "name": "@",
      "service": "_imaps",
      "protocol": "_tcp",
      "priority": 0,
      "weight": 1,
      "port": 993,
      "target": "%mailhost%",
      "ttl": 3600
    },
    {
      "type": "SRV",
      "name": "@",
      "service": "_submission",
      "protocol": "_tcp",
      "priority": 0,
      "weight": 1,
      "port": 587,
      "target": "%mailhost%",
      "ttl": 3600
    },
    {
      "type": "SRV",
      "name": "@",
      "service": "_smtps",
      "protocol": "_tcp",
      "priority": 0,
      "weight": 1,
      "port": 465,
      "target": "%mailhost%",
      "ttl": 3600
    },
    {
      "type": "SRV",
      "name": "@",
      "service": "_pop3s",
      "protocol": "_tcp",
      "priority": 0,
      "weight": 1,
      "port": 995,
      "target": "%mailhost%",
      "ttl": 3600
    }
  ]
}
