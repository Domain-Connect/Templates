{
  "providerId": "shipmail.to",
  "providerName": "Shipmail",
  "serviceId": "email",
  "serviceName": "Shipmail Email",
  "version": 1,
  "syncBlock": false,
  "syncPubKeyDomain": "domainconnect.shipmail.to",
  "syncRedirectDomain": "shipmail.to",
  "logoUrl": "https://shipmail.to/logo.svg",
  "description": "Configures DNS records for Shipmail email.",
  "variableDescription": "%dkim% is the DKIM TXT value generated by Shipmail for this domain.",
  "records": [
    {
      "type": "MX",
      "host": "@",
      "pointsTo": "mx1.shipmail.to",
      "priority": 10,
      "ttl": 300
    },
    {
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:spf.shipmail.to",
      "ttl": 300
    },
    {
      "type": "TXT",
      "host": "shipmail._domainkey",
      "data": "%dkim%",
      "ttl": 300
    },
    {
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=reject",
      "ttl": 300,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DMARC1",
      "essential": "OnApply"
    }
  ]
}
