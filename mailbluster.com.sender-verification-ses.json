{
	"providerId": "mailbluster.com",
	"providerName": "MailBluster",
	"serviceId": "sender-verification-ses",
	"serviceName": "MailBluster Email Sender Verification (AWS SES)",
	"version": 1,
	"logoUrl": "https://mailbluster.com/wp-content/themes/mailbluster/resources/assets/images/mailbluster-logo.svg",
	"description": "Configures DKIM, SPF, DMARC, and Custom Mail From DNS records for MailBluster email sender verification using AWS SES",
	"syncPubKeyDomain": "mailbluster.com",
	"syncRedirectDomain": "mailbluster.com",
	"syncBlock": false,
	"shared": false,
	"multiInstance": true,
	"warnPhishing": false,
	"hostRequired": false,
	"records": [
		{
			"groupId": "dkim",
			"type": "CNAME",
			"host": "%dkimToken1%._domainkey",
			"pointsTo": "%dkimToken1%.dkim.amazonses.com",
			"ttl": 3600
		},
		{
			"groupId": "dkim",
			"type": "CNAME",
			"host": "%dkimToken2%._domainkey",
			"pointsTo": "%dkimToken2%.dkim.amazonses.com",
			"ttl": 3600
		},
		{
			"groupId": "dkim",
			"type": "CNAME",
			"host": "%dkimToken3%._domainkey",
			"pointsTo": "%dkimToken3%.dkim.amazonses.com",
			"ttl": 3600
		},
		{
			"groupId": "spf",
			"type": "SPFM",
			"host": "%sub%",
			"spfRules": "include:amazonses.com"
		},
		{
			"groupId": "dmarc",
			"type": "TXT",
			"host": "_dmarc",
			"data": "%dmarcValue%",
			"ttl": 3600
		},
		{
			"groupId": "custommailfrom",
			"type": "MX",
			"host": "%customMailFromDomain%",
			"pointsTo": "feedback-smtp.%awsRegion%.amazonses.com",
			"priority": 10,
			"ttl": 3600
		}
	]
}