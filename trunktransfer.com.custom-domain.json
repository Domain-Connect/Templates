{
  "providerId": "trunktransfer.com",
  "providerName": "TrunkTransfer",
  "serviceId": "custom-domain",
  "serviceName": "TrunkTransfer Custom Domain",
  "version": 1,
  "logoUrl": "https://trunktransfer.com/logo.png",
  "description":
    "Connect your domain to TrunkTransfer for branded file delivery",
  "syncPubKeyDomain": "domainconnect.trunktransfer.com",
  "syncRedirectDomain": "trunktransfer.com",
  "records": [
    {
      "type": "CNAME",
      "host": "%record_host%",
      "pointsTo": "fallback.trunktransfer.com",
      "ttl": 3600,
      "essential": "Always"
    },
    {
      "type": "TXT",
      "host": "%cf_own_name%",
      "data": "%cf_own_value%",
      "ttl": 300,
      "essential": "Always"
    },
    {
      "type": "TXT",
      "host": "%cf_ssl_name%",
      "data": "%cf_ssl_value%",
      "ttl": 300,
      "essential": "OnApply"
    }
  ]
}