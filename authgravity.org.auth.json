{
  "providerId": "authgravity.org",
  "providerName": "AuthGravity",
  "serviceId": "auth",
  "serviceName": "AuthGravity Domain",
  "logoUrl": "https://authgravity.org/authgravity-logo.png",
  "version": 1,
  "description": "Enables a domain to work with AuthGravity",
  "syncBlock": false,
  "shared": false,
  "hostRequired": true,
  "syncPubKeyDomain": "domainconnect.authgravity.org",
  "records": [
    {
      "type": "CNAME",
      "host": "@",
      "pointsTo": "cname.authgravity.net",
      "ttl": 3600
    }
  ]
}
