{
  "providerId": "rebelsender.com",
  "providerName": "RebelSender",
  "serviceId": "mail",
  "serviceName": "Mail",
  "version": 4,
  "syncPubKeyDomain": "rebelsender.com",
  "syncRedirectDomain": "rebelsender.com",
  "description": "Configure DNS records for email sending with RebelSender.",
  "logoUrl": "https://rebelsender.com/logo.svg",
  "variableDescription": "%DKIM1_HOST%/%DKIM1_VALUE%, %DKIM2_HOST%/%DKIM2_VALUE%, %DKIM3_HOST%/%DKIM3_VALUE%: Easy DKIM CNAME records (AWS SES); %VERIFY_VALUE%: domain ownership verification; %MAILFROM_MX%: MAIL FROM bounce handler; %DMARC_VALUE%: DMARC policy",
  "records": [
    {
      "type": "TXT",
      "host": "@",
      "ttl": 3600,
      "data": "rebelsender-verify=%VERIFY_VALUE%"
    },
    {
      "type": "CNAME",
      "host": "%DKIM1_HOST%",
      "pointsTo": "%DKIM1_VALUE%",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "%DKIM2_HOST%",
      "pointsTo": "%DKIM2_VALUE%",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "%DKIM3_HOST%",
      "pointsTo": "%DKIM3_VALUE%",
      "ttl": 3600
    },
    {
      "type": "MX",
      "host": "mail",
      "pointsTo": "%MAILFROM_MX%",
      "ttl": 3600,
      "priority": 10
    },
    {
      "type": "SPFM",
      "host": "mail",
      "ttl": 3600,
      "spfRules": "include:amazonses.com"
    },
    {
      "type": "CNAME",
      "host": "track",
      "pointsTo": "fallback-tracking.rebelsender.com",
      "ttl": 3600
    },
    {
      "type": "TXT",
      "host": "_dmarc",
      "ttl": 3600,
      "data": "%DMARC_VALUE%",
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DMARC1",
      "essential": "OnApply"
    }
  ]
}
