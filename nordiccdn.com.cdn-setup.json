{
  "providerId": "nordiccdn.com",
  "providerName": "NordicCDN",
  "serviceId": "cdn-setup",
  "serviceName": "NordicCDN CDN Acceleration",
  "version": 1,
  "logoUrl": "https://nordiccdn.com/images/nordiccdn-logo.svg",
  "description": "Configure your domain to use NordicCDN for full-page caching, content delivery acceleration, and automatic SSL certificate provisioning.",
  "variableDescription": "token: Domain ownership verification token. cdnhost: CDN hostname for traffic routing. acmetarget: ACME challenge CNAME target for SSL certificate provisioning.",
  "syncBlock": false,
  "syncPubKeyDomain": "domainconnect.nordiccdn.com",
  "syncRedirectDomain": "nordiccdn.com",
  "hostRequired": true,
  "records": [
     {
      "type": "TXT",
      "host": "_cdn-verification",
      "data": "cdn-verify=%token%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "cdn-verify="
    },
    {
      "type": "CNAME",
      "host": "@",
      "pointsTo": "%cdnhost%",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "_acme-challenge",
      "pointsTo": "%acmetarget%",
      "ttl": 3600
    }
  ]
}
