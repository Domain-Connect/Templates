{
  "providerId": "nelavio.com",
  "providerName": "Nelavio",
  "serviceId": "ownership-verification",
  "serviceName": "Ownership verification",
  "version": 1,
  "description": "Adds a DNS TXT record used to verify domain ownership in Nelavio.",
  "variableDescription": "verificationToken: unique token generated by Nelavio for domain ownership verification",
  "syncBlock": false,
  "syncPubKeyDomain": "nelavio.com",
  "syncRedirectDomain": "app.nelavio.com",
  "multiInstance": true,
  "records": [
    {
      "groupId": "verification",
      "type": "TXT",
      "host": "_nelavio",
      "data": "nelavio-verification=%verificationToken%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "nelavio-verification="
    }
  ]
}
