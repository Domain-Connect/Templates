{
  "providerId": "vnytros.dev",
  "providerName": "Vnytros",
  "serviceId": "custom-domain",
  "serviceName": "Connect Custom Domain",
  "version": 2,
  "logoUrl": "https://public.assets.vnytros.dev/vnytros_logo.svg",
  "description": "Connect your custom domain to Vnytros.",
  "variableDescription": "%ip%: server IP; %ipv6%: IPv6 address; %target%: CNAME destination; %txt%: verification token; %mx_host%: mail server; %mx_priority%: mail priority; %dkim_selector%: DKIM selector; %dkim_key%: DKIM public key; %spf_include%: SPF include domain; %dmarc_email%: DMARC report email",
  "syncPubKeyDomain": "vnytros.dev",
  "records": [
    {
      "type": "A",
      "host": "@",
      "pointsTo": "%ip%",
      "ttl": 3600,
      "group": "web",
      "optional": false
    },
    {
      "type": "AAAA",
      "host": "@",
      "pointsTo": "%ipv6%",
      "ttl": 3600,
      "group": "web",
      "optional": true
    },
    {
      "type": "CNAME",
      "host": "www",
      "pointsTo": "%target%",
      "ttl": 3600,
      "group": "web",
      "optional": false
    },
    {
      "type": "TXT",
      "host": "@",
      "data": "vnytros-verify=%txt%",
      "ttl": 300,
      "group": "verification",
      "optional": false
    },
    {
      "type": "MX",
      "host": "@",
      "pointsTo": "%mx_host%",
      "priority": "%mx_priority%",
      "ttl": 3600,
      "group": "mail",
      "optional": true
    },
    {
      "type": "TXT",
      "host": "@",
      "data": "v=spf1 include:%spf_include% ~all",
      "ttl": 3600,
      "group": "mail",
      "optional": true
    },
    {
      "type": "TXT",
      "host": "%dkim_selector%._domainkey",
      "data": "v=DKIM1; k=rsa; p=%dkim_key%",
      "ttl": 3600,
      "group": "mail",
      "optional": true
    },
    {
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=quarantine; rua=mailto:%dmarc_email%",
      "ttl": 3600,
      "group": "mail",
      "optional": true
    },
    {
      "type": "CAA",
      "host": "@",
      "flags": 0,
      "tag": "issue",
      "data": "letsencrypt.org",
      "ttl": 3600,
      "group": "security",
      "optional": true
    }
  ]
}
