{
  "providerId": "limrun.com",
  "providerName": "Limrun",
  "serviceId": "domain-verification",
  "serviceName": "Domain Verification",
  "version": 1,
  "description": "Verify domain ownership for Limrun organization features such as SSO and auto-join.",
  "variableDescription": "verificationToken is the unique domain verification token generated by Limrun.",
  "syncBlock": false,
  "syncPubKeyDomain": "limrun.com",
  "syncRedirectDomain": "console.limrun.com",
  "records": [
    {
      "type": "TXT",
      "host": "_limrun",
      "ttl": 3600,
      "data": "limrun-domain-verification=%verificationToken%",
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "limrun-domain-verification="
    }
  ]
}
