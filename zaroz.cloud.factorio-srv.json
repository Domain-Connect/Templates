{
  "providerId": "zaroz.cloud",
  "serviceId": "factorio-srv",
  "serviceName": "Zaroz Factorio Hosting",
  "logoUrl": "https://zaroz.cloud/favicon.png",
  "syncPubKeyDomain": "kernel.zaroz.cloud",
  "syncRedirectDomain": "kernel.zaroz.cloud",
  "syncBlock": false,
  "version": 1,
  "providerName": "Zaroz Cloud",
  "description": "Connect a domain you own to a Factorio server hosted on Zaroz Cloud",
  "variableDescription": "target: the server's public IP address; port: the server's external port",
  "records": [
    {
      "type": "A",
      "host": "@",
      "pointsTo": "%target%",
      "essential": "Always",
      "ttl": "300"
    },
    {
      "type": "SRV",
      "name": "@",
      "service": "_factorio",
      "protocol": "_udp",
      "priority": "0",
      "weight": "0",
      "port": "%port%",
      "target": "%fqdn%.",
      "essential": "Always",
      "ttl": "3600"
    }
  ]
}
