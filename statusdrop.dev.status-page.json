{
    "providerId": "statusdrop.dev",
    "providerName": "StatusDrop",
    "serviceId": "status-page",
    "serviceName": "StatusDrop Custom Domain",
    "version": 1,
    "logoUrl": "https://statusdrop.dev/logo.png",
    "description": "Connect your custom domain to your StatusDrop status page",
    "variableDescription": "VERIFICATION_TOKEN is the domain verification token from your StatusDrop dashboard.",
    "syncPubKeyDomain": "statusdrop.dev",
    "syncRedirectDomain": "statusdrop.dev",
    "hostRequired": true,
    "records": [
        {
            "type": "CNAME",
            "host": "@",
            "pointsTo": "cname.statusdrop.dev",
            "ttl": 3600
        },
        {
            "type": "TXT",
            "host": "_statusdrop-verify",
            "data": "statusdrop-verify=%VERIFICATION_TOKEN%",
            "ttl": 3600,
            "txtConflictMatchingMode": "Prefix",
            "txtConflictMatchingPrefix": "statusdrop-verify="
        }
    ]
}
