{
  "providerId": "sendcanary.com",
  "providerName": "SendCanary",
  "serviceId": "dkim-3",
  "serviceName": "DKIM Email Signing (3 records)",
  "version": 1,
  "logoUrl": "https://sendcanary.com/logo.png",
  "description": "Add three DKIM CNAME records to enable email signing for your domain.",
  "variableDescription": "selector1/target1: First DKIM CNAME. selector2/target2: Second. selector3/target3: Third.",
  "syncPubKeyDomain": "sendcanary.com",
  "syncRedirectDomain": "sendcanary.com,app.sendcanary.com",
  "records": [
    {
      "groupId": "dkim1",
      "type": "CNAME",
      "host": "%selector1%._domainkey",
      "pointsTo": "%target1%",
      "ttl": 3600,
      "essential": "OnApply"
    },
    {
      "groupId": "dkim2",
      "type": "CNAME",
      "host": "%selector2%._domainkey",
      "pointsTo": "%target2%",
      "ttl": 3600,
      "essential": "OnApply"
    },
    {
      "groupId": "dkim3",
      "type": "CNAME",
      "host": "%selector3%._domainkey",
      "pointsTo": "%target3%",
      "ttl": 3600,
      "essential": "OnApply"
    }
  ]
}
