interface CloudflareOAuthProps {
  domain: string;
  records: DnsRecordEntry[];
  onSuccess: () => void;
}

const CloudflareOAuth = ({ domain, records, onSuccess }: CloudflareOAuthProps) => {
  const { status, errorMessage, connect, reset } = useCloudflareOAuth({
    domain,
    records,
    onSuccess,
  });

  if (status === 'success') {
    return (
      <div className="flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 px-4 py-3">
        <CheckCircleIcon className="size-5 shrink-0 text-green-600" />
        <div className="flex flex-col gap-0.5">
          <p className="text-sm font-semibold text-gray-900">DNS records added</p>
          <p className="text-sm text-gray-600">
            All 3 records were added to your Cloudflare zone. Validating now...
          </p>
        </div>
      </div>
    );
  }

  if (status === 'error') {
    return (
      <div className="flex flex-col gap-3 rounded-lg border border-red-200 bg-red-50 px-4 py-3">
        <div className="flex items-start gap-3">
          <ExclamationCircleIcon className="size-5 shrink-0 text-red-600" />
          <div className="flex flex-col gap-0.5">
            <p className="text-sm font-semibold text-gray-900">Failed to add records</p>
            <p className="text-sm text-gray-600">{errorMessage}</p>
          </div>
        </div>
        <Button
          variant="ghost"
          size="sm"
          endEnhancer={ArrowPathIcon}
          analytics={{
            eventCategory: 'button-click',
            attributes: {
              eventName: EVENTS.BUTTON_CLICK.BLOG_CONFIG_AUTO_DNS_CLOUDFLARE_RETRY_CLICKED,
              buttonText: 'Try again',
              domain,
            },
          }}
          onClick={reset}
        >
          Try again
        </Button>
      </div>
    );
  }

  return (
    <div className="flex items-center justify-between gap-4 rounded-lg border bg-gray-50 px-4 py-3">
      <div className="flex items-center gap-3">
        <DynamicImage
          src={CloudflareIcon.src}
          alt="Cloudflare"
          width={20}
          height={20}
          className="shrink-0"
        />
        <div className="flex flex-col gap-0.5">
          <p className="text-sm font-semibold text-gray-900">
            Auto-configure with Cloudflare
          </p>
          <p className="text-sm text-gray-600">
            Connect your account and we&apos;ll add all 3 DNS records automatically.
          </p>
        </div>
      </div>
      <Button
        variant="secondary"
        size="sm"
        disabled={status === 'connecting'}
        analytics={{
          eventCategory: 'button-click',
          attributes: {
            eventName: EVENTS.BUTTON_CLICK.BLOG_CONFIG_AUTO_DNS_CLOUDFLARE_CLICKED,
            buttonText: 'Connect Cloudflare',
            domain,
          },
        }}
        onClick={connect}
      >
        {status === 'connecting' ? (
          <span className="flex items-center gap-2">
            <Spinner className="size-4 animate-spin" />
            Connecting...
          </span>
        ) : (
          'Connect Cloudflare'
        )}
      </Button>
    </div>
  );
};

