import { cookies } from 'next/headers';
import { NextRequest, NextResponse } from 'next/server';

import { captureException } from '@sentry/nextjs';

import type { DnsRecordEntry } from '@/app/home/manufacturer/marketing/(dashboard)/blog/configuration/api/types';

type CloudflareOAuthFlowData = {
  domain: string;
  records: DnsRecordEntry[];
  nonce: string;
};

type CloudflareTokenResponse = {
  access_token: string;
  token_type: string;
  expires_in: number;
};

type CloudflareZone = {
  id: string;
  name: string;
};

type CloudflareApiResponse<T> = {
  result: T;
  success: boolean;
  errors: { code: number; message: string }[];
};

/**
 * Builds the HTML page shown inside the OAuth popup.
 * Posts a message to the parent window and closes itself.
 */
function buildPopupHtml(success: boolean, error?: string): string {
  const message = JSON.stringify({ provider: 'cloudflare', success, error });
  return `<!DOCTYPE html>
<html>
  <head><title>Connecting to Cloudflare...</title></head>
  <body>
    <script>
      try {
        window.opener.postMessage(${message}, window.location.origin);
      } catch (e) {}
      window.close();
    </script>
  </body>
</html>`;
}

function popupResponse(success: boolean, error?: string): NextResponse {
  return new NextResponse(buildPopupHtml(success, error), {
    headers: { 'Content-Type': 'text/html' },
  });
}

/**
 * Builds the DNS record body for the Cloudflare API.
 * CAA records use the `data` field; CNAME/A use `content`.
 */
function buildCloudflareRecordBody(record: DnsRecordEntry): Record<string, unknown> {
  if (record.recordType === 'CAA') {
    return {
      type: 'CAA',
      name: record.recordName,
      data: {
        flags: record.flag ?? 0,
        tag: record.tag ?? 'issue',
        value: record.recordValue,
      },
    };
  }

  return {
    type: record.recordType,
    name: record.recordName,
    content: record.recordValue,
    ttl: 1, // auto TTL
    proxied: false, // must be unproxied for SSL/CNAME validation to work
  };
}

/**
 * GET /api/auth/cloudflare/callback
 * Handles the Cloudflare OAuth redirect. Exchanges the auth code for an access
 * token, finds the user's Cloudflare zone matching the domain, adds all DNS
 * records, then closes the popup and posts the result to the parent window.
 *
 * Required env vars:
 *   CLOUDFLARE_CLIENT_ID
 *   CLOUDFLARE_CLIENT_SECRET
 *   CLOUDFLARE_REDIRECT_URI
 */
export async function GET(request: NextRequest) {
  const { searchParams } = new URL(request.url);
  const code = searchParams.get('code');
  const state = searchParams.get('state');
  const oauthError = searchParams.get('error');

  if (oauthError || !code) {
    return popupResponse(false, oauthError ?? 'Cloudflare authorization was denied.');
  }

  // Retrieve and validate the flow cookie
  const flowCookie = cookies().get('cf_oauth_flow');
  if (!flowCookie) {
    return popupResponse(false, 'Session expired. Please try again.');
  }

  let flowData: CloudflareOAuthFlowData;
  try {
    flowData = JSON.parse(flowCookie.value) as CloudflareOAuthFlowData;
  } catch {
    return popupResponse(false, 'Invalid session data. Please try again.');
  }

  const { domain, records, nonce } = flowData;

  // CSRF check — state must match the nonce stored in the cookie
  if (state !== nonce) {
    return popupResponse(false, 'State mismatch. Please try again.');
  }

  try {
    // 1. Exchange authorization code for access token
    const tokenRes = await fetch('https://dash.cloudflare.com/oauth2/token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        grant_type: 'authorization_code',
        code,
        client_id: process.env.CLOUDFLARE_CLIENT_ID ?? '',
        client_secret: process.env.CLOUDFLARE_CLIENT_SECRET ?? '',
        redirect_uri: process.env.CLOUDFLARE_REDIRECT_URI ?? '',
      }),
    });

    if (!tokenRes.ok) {
      const body = await tokenRes.text();
      captureException(new Error(`Cloudflare token exchange failed: ${body}`), {
        tags: { feature: 'blog-config', operation: 'cloudflare-oauth-token' },
      });
      return popupResponse(false, 'Failed to authenticate with Cloudflare. Please try again.');
    }

    const { access_token } = (await tokenRes.json()) as CloudflareTokenResponse;

    // 2. Find the Cloudflare zone matching the root domain (e.g. blog.example.com → example.com)
    const rootDomain = domain.split('.').slice(-2).join('.');
    const zonesRes = await fetch(
      `https://api.cloudflare.com/client/v4/zones?name=${rootDomain}&status=active`,
      { headers: { Authorization: `Bearer ${access_token}` } },
    );

    const zonesData = (await zonesRes.json()) as CloudflareApiResponse<CloudflareZone[]>;

    if (!zonesData.success || !zonesData.result?.length) {
      return popupResponse(
        false,
        `Domain ${rootDomain} was not found in your Cloudflare account. Make sure this domain is active in Cloudflare.`,
      );
    }

    const zone = zonesData.result[0];

    // 3. Add each DNS record to the zone
    for (const record of records) {
      const body = buildCloudflareRecordBody(record);

      const addRes = await fetch(
        `https://api.cloudflare.com/client/v4/zones/${zone.id}/dns_records`,
        {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${access_token}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(body),
        },
      );

      const addData = (await addRes.json()) as CloudflareApiResponse<unknown>;

      if (!addData.success) {
        const errMessage = addData.errors?.[0]?.message ?? `Failed to add ${record.recordType} record`;

        // "already exists" is not a real failure — skip it
        if (!errMessage.toLowerCase().includes('already exists')) {
          captureException(
            new Error(`Cloudflare DNS record add failed: ${errMessage}`),
            {
              tags: { feature: 'blog-config', operation: 'cloudflare-add-record' },
              extra: { domain, recordType: record.recordType, zoneId: zone.id },
            },
          );
          return popupResponse(false, errMessage);
        }
      }
    }

    // 4. Clear the flow cookie and signal success to the parent window
    cookies().delete('cf_oauth_flow');

    return popupResponse(true);
  } catch (err) {
    captureException(err, {
      tags: { feature: 'blog-config', operation: 'cloudflare-oauth-callback' },
      extra: { domain },
    });
    return popupResponse(false, 'An unexpected error occurred. Please try again.');
  }
}

import crypto from 'crypto';

import { cookies } from 'next/headers';
import { NextRequest, NextResponse } from 'next/server';

import type { DnsRecordEntry } from '@/app/home/manufacturer/marketing/(dashboard)/blog/configuration/api/types';

type CloudflareOAuthFlowData = {
  domain: string;
  records: DnsRecordEntry[];
  nonce: string;
};

/**
 * GET /api/auth/cloudflare
 * Initiates Cloudflare OAuth flow. Stores domain + DNS records in a short-lived
 * httpOnly cookie, then redirects to Cloudflare's OAuth authorization page.
 *
 * Required env vars:
 *   CLOUDFLARE_CLIENT_ID       — from your registered Cloudflare OAuth app
 *   CLOUDFLARE_REDIRECT_URI    — must match the redirect URI in your Cloudflare app
 *                                e.g. https://yourdomain.com/api/auth/cloudflare/callback
 */
export async function GET(request: NextRequest) {
  const { searchParams } = new URL(request.url);
  const domain = searchParams.get('domain');
  const recordsParam = searchParams.get('records');

  if (!domain || !recordsParam) {
    return NextResponse.json(
      { error: 'Missing required params: domain, records' },
      { status: 400 },
    );
  }

  let records: DnsRecordEntry[];
  try {
    records = JSON.parse(recordsParam) as DnsRecordEntry[];
  } catch {
    return NextResponse.json({ error: 'Invalid records format' }, { status: 400 });
  }

  const nonce = crypto.randomBytes(16).toString('hex');

  const flowData: CloudflareOAuthFlowData = { domain, records, nonce };

  cookies().set('cf_oauth_flow', JSON.stringify(flowData), {
    httpOnly: true,
    secure: process.env.NODE_ENV === 'production',
    maxAge: 600, // 10 minutes — enough time to complete OAuth
    path: '/',
    sameSite: 'lax',
  });

  const authUrl = new URL('https://dash.cloudflare.com/oauth2/auth');
  authUrl.searchParams.set('response_type', 'code');
  authUrl.searchParams.set('client_id', process.env.CLOUDFLARE_CLIENT_ID ?? '');
  authUrl.searchParams.set('redirect_uri', process.env.CLOUDFLARE_REDIRECT_URI ?? '');
  // zone:read — list zones to find the matching zone ID
  // zone.dns:edit — create DNS records in the zone
  authUrl.searchParams.set('scope', 'zone:read zone.dns:edit');
  authUrl.searchParams.set('state', nonce);

  return NextResponse.redirect(authUrl.toString());
}

