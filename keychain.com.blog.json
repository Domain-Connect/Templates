'use client';

import { useCallback, useEffect, useRef, useState } from 'react';

import { useRudderStack } from '@keychain/services/analytics/rudderstack';
import EVENTS from '@keychain/shared/constant/events';
import { captureException } from '@sentry/nextjs';

import type { DnsRecordEntry } from '../../../api/types';

export type CloudflareOAuthStatus = 'idle' | 'connecting' | 'success' | 'error';

type OAuthMessagePayload = {
  provider: string;
  success: boolean;
  error?: string;
};

type UseCloudflareOAuthParams = {
  domain: string;
  records: DnsRecordEntry[];
  onSuccess: () => void;
};

type UseCloudflareOAuthResult = {
  status: CloudflareOAuthStatus;
  errorMessage: string | null;
  connect: () => void;
  reset: () => void;
};

export const useCloudflareOAuth = ({
  domain,
  records,
  onSuccess,
}: UseCloudflareOAuthParams): UseCloudflareOAuthResult => {
  const { track } = useRudderStack();
  const [status, setStatus] = useState<CloudflareOAuthStatus>('idle');
  const [errorMessage, setErrorMessage] = useState<string | null>(null);

  const popupRef = useRef<Window | null>(null);
  const messageHandlerRef = useRef<((event: MessageEvent) => void) | null>(null);
  const pollIntervalRef = useRef<ReturnType<typeof setInterval> | null>(null);

  const cleanup = useCallback(() => {
    if (messageHandlerRef.current) {
      window.removeEventListener('message', messageHandlerRef.current);
      messageHandlerRef.current = null;
    }
    if (pollIntervalRef.current) {
      clearInterval(pollIntervalRef.current);
      pollIntervalRef.current = null;
    }
  }, []);

  // Always cleanup listeners on unmount
  useEffect(() => {
    return cleanup;
  }, [cleanup]);

  const connect = useCallback(() => {
    cleanup();
    setStatus('connecting');
    setErrorMessage(null);

    const params = new URLSearchParams({
      domain,
      records: JSON.stringify(records),
    });

    const popup = window.open(
      `/api/auth/cloudflare?${params.toString()}`,
      'cloudflare-oauth',
      'width=600,height=700,scrollbars=yes,resizable=yes',
    );

    if (!popup) {
      setStatus('error');
      setErrorMessage('Popup was blocked. Please allow popups for this site and try again.');
      return;
    }

    popupRef.current = popup;

    const handleMessage = (event: MessageEvent) => {
      if (event.origin !== window.location.origin) return;

      const data = event.data as OAuthMessagePayload;
      if (data?.provider !== 'cloudflare') return;

      cleanup();

      if (data.success) {
        setStatus('success');
        track('user-activity', {
          eventName: EVENTS.BUTTON_CLICK.BLOG_CONFIG_AUTO_DNS_CLOUDFLARE_SUCCESS,
          domain,
        });
        onSuccess();
      } else {
        const errMsg = data.error ?? 'Failed to add DNS records. Please try again.';
        setStatus('error');
        setErrorMessage(errMsg);
        captureException(new Error(`Cloudflare OAuth DNS setup failed: ${errMsg}`), {
          tags: { feature: 'blog-config', operation: 'cloudflare-oauth' },
          extra: { domain },
        });
        track('user-activity', {
          eventName: EVENTS.BUTTON_CLICK.BLOG_CONFIG_AUTO_DNS_CLOUDFLARE_FAILED,
          domain,
          error: errMsg,
        });
      }
    };

    messageHandlerRef.current = handleMessage;
    window.addEventListener('message', handleMessage);

    // If user closes the popup without completing OAuth, reset to idle
    pollIntervalRef.current = setInterval(() => {
      if (popup.closed) {
        cleanup();
        setStatus(prev => (prev === 'connecting' ? 'idle' : prev));
      }
    }, 500);
  }, [domain, records, onSuccess, track, cleanup]);

  const reset = useCallback(() => {
    cleanup();
    setStatus('idle');
    setErrorMessage(null);
  }, [cleanup]);

  return { status, errorMessage, connect, reset };
};

# Domain Connect Setup

## 1. DNS TXT Record — Add to keychain.com DNS

Add this TXT record to your production domain's DNS (wherever keychain.com is hosted):

| Field | Value |
|-------|-------|
| **Type** | TXT |
| **Host / Name** | `_dck1` |
| **Value** | `p=1,a=RS256,` |
| **TTL** | 300 |

This allows DNS providers (Cloudflare, GoDaddy, etc.) to verify that apply requests are genuinely signed by Keychain.

## 2. Submit Template PR to Domain Connect

The template file is at `domain-connect/keychain.com.blog.json`.

Steps:
1. Fork https://github.com/Domain-Connect/Templates
2. Copy `keychain.com.blog.json` into the root of the forked repo
3. Open a PR with title: `Add Keychain blog template`
4. The community will review for security and variable scope

## 3. Contact DNS Providers

After the template PR is merged, email each provider to onboard the template:

| Provider | Contact |
|----------|---------|
| Cloudflare | domain-connect@cloudflare.com |
| GoDaddy | domainconnect@godaddy.com |
| IONOS | domain_connect_admin@domain.ionos.com |
| Vercel | domainconnect@vercel.com |
| NameSilo | domainconnect@namesilo.com |

## 4. Private Key

The RSA private key is stored in `apps/dashboard/.env.local` as `DOMAIN_CONNECT_PRIVATE_KEY`.
Add the same variable to your production environment (Vercel/server env vars).

**Never commit the private key to git.**

## Template Variables

When building the apply URL, pass these variables:

| Variable | Example value | Source |
|----------|--------------|--------|
| `blogHost` | `blog` | Parsed from user's chosen subdomain |
| `blogTarget` | `blog-proxy.keychain.com` | Your static blog server hostname |
| `sslHost` | `_abc123.blog` | From `AcmStepMetadata.ssl_record.recordName` (strip root domain) |
| `sslTarget` | `_xyz.acm-validations.aws.` | From `AcmStepMetadata.ssl_record.recordValue` |

{
  "providerId": "keychain.com",
  "providerName": "Keychain",
  "serviceId": "blog",
