{
  "providerId": "sendvoya.com",
  "providerName": "Sendvoya",
  "serviceId": "mail-sending",
  "serviceName": "Mail Sending",
  "sharedServiceName": true,
  "version": 1,
  "logoUrl": "https://app.sendvoya.com/favicon.svg",
  "description": "Configure SPF, DKIM, return-path, DMARC and tracking records for Sendvoya email sending.",
  "variableDescription": "dkimselector and dkimpublickey are generated by Sendvoya for the selected sending domain.",
  "syncBlock": false,
  "syncPubKeyDomain": "sendvoya.com",
  "syncRedirectDomain": "app.sendvoya.com,sendvoya.com",
  "records": [
    {
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:_spf.sendvoya.com",
      "ttl": 3600
    },
    {
      "type": "SPFM",
      "host": "svy",
      "spfRules": "include:_spf.sendvoya.com",
      "ttl": 3600
    },
    {
      "type": "TXT",
      "host": "%dkimselector%._domainkey",
      "data": "v=DKIM1; k=rsa; p=%dkimpublickey%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DKIM1"
    },
    {
      "type": "MX",
      "host": "bounce-svy",
      "pointsTo": "mta01.mx.sendvoya.com",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "SPFM",
      "host": "bounce-svy",
      "spfRules": "include:_spf.sendvoya.com",
      "ttl": 3600
    },
    {
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=none; sp=none; adkim=r; aspf=r;",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DMARC1",
      "essential": "OnApply"
    },
    {
      "type": "CNAME",
      "host": "go-svy",
      "pointsTo": "track.sendvoya.com",
      "ttl": 3600
    }
  ]
}
