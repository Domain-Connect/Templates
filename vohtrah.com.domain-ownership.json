{
  "providerId": "vohtrah.com",
  "providerName": "Vohtrah",
  "serviceId": "domain-ownership",
  "serviceName": "Sending domain ownership",
  "version": 1,
  "logoUrl": "https://vohtrah.com/logo.svg",
  "description": "Adds the TXT record needed to verify ownership of a customer-owned Vohtrah sending domain.",
  "variableDescription": "%verificationToken%: sending domain ownership token generated by Vohtrah.",
  "syncPubKeyDomain": "domainconnect.vohtrah.com",
  "syncRedirectDomain": "vohtrah.com,www.vohtrah.com,app.vohtrah.com",
  "syncBlock": false,
  "records": [
    {
      "type": "TXT",
      "host": "@",
      "data": "vohtrah-domain-verification=%verificationToken%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "vohtrah-domain-verification=",
      "essential": "OnApply"
    }
  ]
}
