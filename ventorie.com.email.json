{
  "providerId": "ventorie.com",
  "providerName": "Ventorie",
  "serviceId": "email",
  "serviceName": "Ventorie email (sending + replies)",
  "version": 1,
  "logoUrl": "https://ventorie.com/logo.svg",
  "description": "Sets up verified-domain email for Ventorie: outbound sending (SPF, DKIM, return-path on the vsend subdomain) and the reply subdomain that routes vendor replies back into your Ventorie inbox. No records are written on the domain apex, so existing mailboxes (Google Workspace, Microsoft 365) are untouched.",
  "syncBlock": false,
  "syncRedirectDomain": "app.ventorie.com",
  "syncPubKeyDomain": "ventorie.com",
  "records": [
    {
      "type": "SPFM",
      "host": "vsend",
      "spfRules": "include:amazonses.com"
    },
    {
      "type": "MX",
      "host": "vsend",
      "pointsTo": "feedback-smtp.us-east-1.amazonses.com",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "TXT",
      "host": "resend._domainkey",
      "data": "%dkim%",
      "txtConflictMatchingMode": "All",
      "ttl": 3600
    },
    {
      "type": "MX",
      "host": "reply",
      "pointsTo": "inbound-smtp.us-east-1.amazonaws.com",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "SPFM",
      "host": "vsend.reply",
      "spfRules": "include:amazonses.com"
    },
    {
      "type": "MX",
      "host": "vsend.reply",
      "pointsTo": "feedback-smtp.us-east-1.amazonses.com",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "TXT",
      "host": "resend._domainkey.reply",
      "data": "%replydkim%",
      "txtConflictMatchingMode": "All",
      "ttl": 3600
    }
  ]
}
