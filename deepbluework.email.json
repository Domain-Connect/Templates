{
  "providerId": "deepbluework",
  "providerName": "Deepbluework",
  "serviceId": "email",
  "serviceName": "Email Provider",
  "version": 2,
  "logoUrl": "https://app.deepbluework.com/logo.png",
  "description": "Configure your domain to send and receive email with Deepbluework.",
  "variableDescription": "dkimSelector: DKIM selector assigned by Deepbluework; dkimValue: DKIM public key record value; dmarcValue: DMARC policy record value; bimiLogoUrl: HTTPS URL to the domain BIMI-compliant SVG logo (SVG Tiny 1.2, square).",
  "syncPubKeyDomain": "deepbluework.com",
  "syncRedirectDomain": "deepbluework.com",
  "records": [
    {
      "groupId": "mx",
      "type": "MX",
      "host": "@",
      "pointsTo": "mail.deepbluework.com.",
      "priority": 10,
      "ttl": 3600
    },
    {
      "groupId": "mx",
      "type": "MX",
      "host": "@",
      "pointsTo": "mailsec.deepbluework.com.",
      "priority": 20,
      "ttl": 3600
    },
    {
      "groupId": "spf",
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:_spf.deepbluework.com mx",
      "ttl": 3600
    },
    {
      "groupId": "dkim",
      "type": "TXT",
      "host": "%dkimSelector%._domainkey",
      "data": "%dkimValue%",
      "ttl": 3600,
      "txtConflictMatchingMode": "All"
    },
    {
      "groupId": "dmarc",
      "type": "TXT",
      "host": "_dmarc",
      "data": "%dmarcValue%",
      "ttl": 3600,
      "txtConflictMatchingMode": "All",
      "essential": "OnApply"
    },
    {
      "groupId": "bimi",
      "type": "TXT",
      "host": "default._bimi",
      "data": "v=BIMI1; l=%bimiLogoUrl%;",
      "ttl": 3600,
      "txtConflictMatchingMode": "All",
      "essential": "OnApply"
    }
  ]
}
