{
  "providerId": "cybertemp.xyz",
  "providerName": "CyberTemp",
  "serviceId": "email",
  "serviceName": "CyberTemp Email",
  "version": 1,
  "logoUrl": "https://cybertemp.xyz/icon.png",
  "description": "Configure your domain to send and receive email through CyberTemp.",
  "syncPubKeyDomain": "cybertemp.xyz",
  "syncRedirectDomain": "cybertemp.xyz",
  "syncBlock": false,
  "shared": false,
  "variableDescription": "%ip% is the CyberTemp mail server IP address (signed into the apply URL by CyberTemp at runtime).",
  "records": [
    {
      "type": "MX",
      "host": "@",
      "pointsTo": "mail.%domain%",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "MX",
      "host": "*",
      "pointsTo": "mail.%domain%",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "A",
      "host": "mail",
      "pointsTo": "%ip%",
      "ttl": 3600
    },
    {
      "type": "SPFM",
      "host": "@",
      "spfRules": "ip4:%ip% include:_spf.google.com"
    }
  ]
}
