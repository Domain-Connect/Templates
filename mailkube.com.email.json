{
  "providerId": "mailkube.com",
  "providerName": "Mailkube",
  "serviceId": "email",
  "serviceName": "Mailkube Email Authentication",
  "version": 2,
  "logoUrl": "https://cdn.mailkube.com/public/logos/domainconnect/packv1.png",
  "syncPubKeyDomain": "mailkube.com",
  "syncRedirectDomain": "app.mailkube.com",
  "description": "Configures DKIM and DMARC on the domain, inbound MX, and the send.<domain> return-path records (MX + SPF) for sending and receiving email via Mailkube.",
  "records": [
    {
      "groupId": "dkim",
      "type": "TXT",
      "host": "%dkimSelector%._domainkey",
      "data": "v=DKIM1; k=rsa; p=%dkimKey%",
      "ttl": 3600,
      "essential": "OnApply"
    },
    {
      "groupId": "spf",
      "type": "SPFM",
      "host": "send",
      "spfRules": "%spfRules%",
      "ttl": 3600
    },
    {
      "groupId": "dmarc",
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=%dmarcPolicy%; rua=mailto:%dmarcRua%; ruf=mailto:%dmarcRuf%",
      "ttl": 3600,
      "txtConflictMatchingMode": "All",
      "essential": "OnApply"
    },
    {
      "groupId": "mx_inbound",
      "type": "MX",
      "host": "@",
      "pointsTo": "%mxPointsTo%",
      "priority": 10,
      "ttl": 3600
    },
    {
      "groupId": "mx_send",
      "type": "MX",
      "host": "send",
      "pointsTo": "%sendPointsTo%",
      "priority": 10,
      "ttl": 3600
    }
  ]
}
