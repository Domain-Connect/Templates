{
  "providerId": "heybrand.ai",
  "providerName": "heybrand",
  "serviceId": "page-subdomain",
  "serviceName": "heybrand Page",
  "version": 2,
  "description": "Serve a heybrand page on a subdomain of your domain.",
  "syncPubKeyDomain": "heybrand.ai",
  "syncRedirectDomain": "heybrand.ai",
  "hostRequired": true,
  "records": [
    {
      "type": "CNAME",
      "host": "@",
      "pointsTo": "%target%",
      "ttl": 3600
    },
    {
      "type": "TXT",
      "host": "_acme-challenge",
      "data": "%ssltxt%",
      "ttl": 3600,
      "txtConflictMatchingMode": "All",
      "essential": "OnApply"
    },
    {
      "type": "TXT",
      "host": "_cf-custom-hostname",
      "data": "%ownertxt%",
      "ttl": 3600,
      "txtConflictMatchingMode": "All",
      "essential": "OnApply"
    }
  ]
}
