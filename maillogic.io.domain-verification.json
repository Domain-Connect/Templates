{
  "providerId": "maillogic.io",
  "providerName": "MailLogic",
  "serviceId": "domain-verification",
  "serviceName": "Domain Verification",
  "version": 1,
  "logoUrl": "https://maillogic.io/static/images/mail-orbit-logo.svg",
  "description": "Adds a TXT record used by MailLogic to verify control of a domain.",
  "variableDescription": "%VERIFY_TOKEN%: verification token generated by MailLogic",
  "syncPubKeyDomain": "keys.maillogic.io",
  "syncRedirectDomain": "dc-lab.maillogic.io",
  "records": [
    {
      "type": "TXT",
      "host": "maillogic-verification",
      "data": "maillogic-verification=%VERIFY_TOKEN%",
      "ttl": 300,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "maillogic-verification="
    }
  ]
}
