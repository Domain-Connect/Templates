{
  "providerId": "reeva.me",
  "providerName": "Reeva.me",
  "serviceId": "mail",
  "serviceName": "Reeva Mail",
  "description": "Reeva.me mail service: MX (mx1/mx2.reeva.me), SPF (via SPFM), per-domain DKIM (algorithm set by Stalwart), DMARC, MTA-STS + TLS-RPT, and autoconfig/autodiscover CNAMEs for Thunderbird + Outlook auto-setup.",
  "logoUrl": "https://app.reeva.me/auth-bg.png",
  "version": 2,
  "syncBlock": false,
  "syncPubKeyDomain": "reeva.me",
  "syncRedirectDomain": "app.reeva.me",
  "shared": false,
  "variableDescription": "dkim_selector, dkim_pub and dkim_alg are minted per customer domain by Reeva from the live Stalwart signing key (see /api/v1/domains/{id}/dns) and embedded in the apply URL. dkim_alg is the key algorithm (rsa or ed25519) so the published DKIM record matches what Stalwart actually signs with. The selector is the only domain-customizable part of the DKIM record name; nothing else uniquely identifies the key — hence the bare variable in host.",
  "records": [
    { "type": "MX",    "host": "@",                          "pointsTo": "mx1.reeva.me",                                    "priority": 10, "ttl": 300 },
    { "type": "MX",    "host": "@",                          "pointsTo": "mx2.reeva.me",                                    "priority": 20, "ttl": 300 },
    { "type": "SPFM",  "host": "@",                          "spfRules": "mx" },
    { "type": "TXT",   "host": "_dmarc",                     "data": "v=DMARC1; p=none; rua=mailto:dmarc@%domain%",          "ttl": 300, "txtConflictMatchingMode": "Prefix", "txtConflictMatchingPrefix": "v=DMARC1", "essential": "OnApply" },
    { "type": "TXT",   "host": "%dkim_selector%._domainkey", "data": "v=DKIM1; k=%dkim_alg%; p=%dkim_pub%",                  "ttl": 300, "txtConflictMatchingMode": "All" },
    { "type": "TXT",   "host": "_mta-sts",                   "data": "v=STSv1; id=20260601",                                "ttl": 300, "txtConflictMatchingMode": "Prefix", "txtConflictMatchingPrefix": "v=STSv1" },
    { "type": "TXT",   "host": "_smtp._tls",                 "data": "v=TLSRPTv1; rua=mailto:postmaster@reeva.me",          "ttl": 300, "txtConflictMatchingMode": "Prefix", "txtConflictMatchingPrefix": "v=TLSRPTv1" },
    { "type": "CNAME", "host": "autoconfig",                 "pointsTo": "webmail.reeva.me",                                "ttl": 300 },
    { "type": "CNAME", "host": "autodiscover",               "pointsTo": "webmail.reeva.me",                                "ttl": 300 },
    { "type": "CNAME", "host": "mta-sts",                    "pointsTo": "webmail.reeva.me",                                "ttl": 300 }
  ]
}
