{
  "providerId": "rvn-app.com",
  "providerName": "Revyn Media",
  "serviceId": "branded-site",
  "serviceName": "Branded Website",
  "version": 2,
  "logoUrl": "https://media.rvn-app.com/brand/logo.png",
  "description": "Point your domain at your Revyn Media branded site.",
  "syncBlock": false,
  "syncPubKeyDomain": "rvn-app.com",
  "records": [
    {
      "type": "CNAME",
      "host": "www",
      "pointsTo": "sites.rvn-app.com",
      "ttl": 3600
    },
    {
      "type": "REDIR301",
      "host": "@",
      "target": "%redirectTarget%",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "book",
      "pointsTo": "booking.rvn-app.com",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "checkin",
      "pointsTo": "checkin.rvn-app.com",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "portal",
      "pointsTo": "portal.rvn-app.com",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "dashboard",
      "pointsTo": "dashboard.rvn-app.com",
      "ttl": 3600
    }
  ]
}
