{
  "providerId": "purple.ai",
  "providerName": "Purple.ai",
  "serviceId": "sendgrid-email",
  "serviceName": "Purple.ai Email Authentication",
  "version": 1,
  "logoUrl": "https://d1ldbb6wxu8wdm.cloudfront.net/33815c0fcf008942e52db4c68969c433.png",
  "description": "Configures DKIM authentication and SPF records for email delivery via SendGrid.",
  "syncBlock": false,
  "syncPubKeyDomain": "domainconnect.purple.ai",
  "syncRedirectDomain": "domainconnect.purple.ai",
  "shared": false,
  "hostRequired": false,
  "records": [
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim1Host%",
      "pointsTo": "%dkim1Value%",
      "ttl": 3600
    },
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim2Host%",
      "pointsTo": "%dkim2Value%",
      "ttl": 3600
    },
    {
      "groupId": "spf",
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:sendgrid.net",
      "ttl": 3600
    }
  ]
}
