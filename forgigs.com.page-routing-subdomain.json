{
    "providerId": "forgigs.com",
    "providerName": "Forgigs",
    "serviceId": "page-routing-subdomain",
    "serviceName": "Connect your subdomain to Forgigs",
    "version": 1,
    "logoUrl": "https://pages.forgigs.com/logo.svg",
    "description": "Points your subdomain (e.g. www.example.com) to your Forgigs page by creating a CNAME record.",
    "variableDescription": "%vercel_cname%: Forgigs CNAME target address",
    "syncPubKeyDomain": "keys.forgigs.com",
    "syncRedirectDomain": "pages.forgigs.com",
    "hostRequired": true,
    "records": [
        {
            "type": "CNAME",
            "host": "@",
            "pointsTo": "%vercel_cname%",
            "ttl": 3600
        }
    ]
}
