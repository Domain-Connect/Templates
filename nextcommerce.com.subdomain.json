{
    "providerId": "nextcommerce.com",
    "providerName": "NextCommerce",
    "serviceId": "subdomain",
    "serviceName": "Connect Store Sub Domain",
    "version": 2,
    "logoUrl": "https://nextcommerce-public-assets.s3.us-east-1.amazonaws.com/final-logo-dark-stroked-md.png",
    "description": "Connects your domain to your NextCommerce store for DEVELOPMENT",
    "variableDescription": "cname is the DNS CNAME target for the NextCommerce store subdomain.",
    "syncPubKeyDomain": "29next.store",
    "syncRedirectDomain": "29next.store",
    "hostRequired": true,
    "records": [
     {
        "type":"CNAME",
        "host":"@",
        "pointsTo":"%cname%",
        "ttl":3600
     }
  ]
}

