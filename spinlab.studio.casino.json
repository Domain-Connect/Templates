{
  "providerId": "spinlab.studio",
  "providerName": "Spinlab",
  "serviceId": "casino",
  "serviceName": "Spinlab Casino Platform",
  "description": "Configures DNS records for hosting a white-label casino website and email sending with Spinlab.",
  "variableDescription": "resend_dkim: DKIM public key for email authentication (provided by Resend API)",
  "version": 4,
  "logoUrl": "https://cdn.spinlab.studio/logo-spinlab.svg",
  "syncBlock": false,
  "syncPubKeyDomain": "spinlab.studio",
  "syncRedirectDomain": "app.spinlab.studio",
  "hostRequired": true,
  "records": [
    {
      "type": "CNAME",
      "host": "@",
      "pointsTo": "apex.spinlab.studio",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "www",
      "pointsTo": "apex.spinlab.studio",
      "ttl": 3600
    },
    {
      "type": "CNAME",
      "host": "api",
      "pointsTo": "apex.spinlab.studio",
      "ttl": 3600
    },
    {
      "type": "MX",
      "host": "send",
      "pointsTo": "feedback-smtp.eu-west-1.amazonses.com",
      "priority": 10,
      "ttl": 3600
    },
    {
      "type": "SPFM",
      "host": "send",
      "spfRules": "include:amazonses.com"
    },
    {
      "type": "TXT",
      "host": "resend._domainkey",
      "data": "p=%resend_dkim%",
      "ttl": 3600
    }
  ]
}
