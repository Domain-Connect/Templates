{
  "providerId": "furimoe.com",
  "providerName": "Furimoe",
  "serviceId": "domain-verification",
  "serviceName": "Furimoe Domain Verification",
  "version": 1,
  "logoUrl": "https://cdn.masuru.in.th/storage/furimoe/furimoe-logo-2x1.webp",
  "description": "Verifies domain ownership for Furimoe services by creating a TXT record",
  "variableDescription": "verifytxt: verification token issued by Furimoe",
  "syncPubKeyDomain": "furimoe.com",
  "syncRedirectDomain": "static.furimoe.com",
  "records": [
    {
      "groupId": "verify",
      "type": "TXT",
      "host": "_furimoe-challenge",
      "data": "token=%verifytxt%",
      "ttl": 3600
    }
  ]
}
