{
	"providerId": "mailbluster.com",
	"providerName": "MailBluster",
	"serviceId": "sender-verification-postmark",
	"serviceName": "MailBluster Email Sender Verification (Postmark)",
	"version": 1,
	"logoUrl": "https://mailbluster.com/wp-content/themes/mailbluster/resources/assets/images/mailbluster-logo.svg",
	"description": "Configures DKIM, SPF, DMARC, and Return Path DNS records for MailBluster email sender verification using Postmark",
	"syncPubKeyDomain": "mailbluster.com",
	"syncRedirectDomain": "mailbluster.com",
	"syncBlock": false,
	"shared": false,
	"multiInstance": true,
	"warnPhishing": false,
	"hostRequired": false,
	"records": [
		{
			"groupId": "dkim",
			"type": "TXT",
			"host": "%dkimHost%._domainkey",
			"data": "%dkimValue%",
			"ttl": 3600
		},
		{
			"groupId": "spf",
			"type": "SPFM",
			"host": "%sub%",
			"spfRules": "include:spf.mtasv.net"
		},
		{
			"groupId": "dmarc",
			"type": "TXT",
			"host": "_dmarc",
			"data": "%dmarcValue%",
			"ttl": 3600
		},
		{
			"groupId": "returnpath",
			"type": "CNAME",
			"host": "%returnPathDomain%",
			"pointsTo": "%returnPathValue%",
			"ttl": 3600
		}
	]
}