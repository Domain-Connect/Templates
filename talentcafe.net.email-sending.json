{
  "providerId": "talentcafe.net",
  "providerName": "TalentCafe",
  "serviceId": "email-sending",
  "serviceName": "Email Sending Setup",
  "version": 1,
  "logoUrl": "https://talentcafe.net/logo.png",
  "description": "This will configure your SPF, DKIM, and MX records to send emails via TalentCafe.",
  "variableDescription": "dkim_value represents the string value for the DKIM TXT record public key.",
  "syncPubKeyDomain": "talentcafe.net",
  "records": [
    {
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:amazonses.com",
      "ttl": 3600
    },
    {
      "type": "TXT",
      "host": "resend._domainkey",
      "data": "%dkim_value%",
      "ttl": 3600
    },
    {
      "type": "MX",
      "host": "@",
      "pointsTo": "feedback-smtp.us-east-1.amazonses.com",
      "priority": 10,
      "ttl": 3600
    }
  ]
}
