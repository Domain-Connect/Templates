{
  "providerId": "openlen.com",
  "providerName": "OpenLen",
  "serviceId": "custom-domain-apex",
  "serviceName": "OpenLen Custom Apex Domain",
  "syncPubKeyDomain": "dc.openlen.com",
  "version": 1,
  "logoUrl": "https://openlen.com/icon.svg",
  "description": "Connect your root domain (e.g. yoursite.com) to your OpenLen landing page.",
  "variableDescription": "token is the per-claim verification value generated when the user adds the domain in OpenLen.",
  "records": [
    {
      "type": "A",
      "host": "@",
      "pointsTo": "178.156.175.171",
      "ttl": 300
    },
    {
      "type": "TXT",
      "host": "_openlen-challenge",
      "data": "%token%",
      "ttl": 300
    }
  ]
}
