{
  "providerId": "sendix.dev",
  "providerName": "Sendix",
  "serviceId": "mail",
  "serviceName": "Mail",
  "version": 1,
  "syncPubKeyDomain": "sendix.dev",
  "syncRedirectDomain": "sendix.dev",
  "description": "Configure DNS records for sending email with Sendix.",
  "logoUrl": "https://sendix.dev/brand/sendix-wordmark.svg",
  "variableDescription": "%dkimSelector%: DKIM selector. %dkimPublicKey%: full DKIM TXT value generated by Sendix, normally starting with v=DKIM1.",
  "records": [
    {
      "groupId": "dkim",
      "type": "TXT",
      "host": "%dkimSelector%._domainkey",
      "ttl": 3600,
      "data": "%dkimPublicKey%",
      "essential": "OnApply",
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DKIM1"
    },
    {
      "groupId": "spf",
      "type": "SPFM",
      "host": "@",
      "ttl": 3600,
      "spfRules": "include:mail.sendix.dev"
    },
    {
      "groupId": "dmarc",
      "type": "TXT",
      "host": "_dmarc",
      "ttl": 3600,
      "data": "v=DMARC1; p=none; rua=mailto:dmarc-reports@sendix.dev; aspf=r; adkim=r",
      "essential": "OnApply",
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DMARC1"
    },
    {
      "groupId": "return-path",
      "type": "CNAME",
      "host": "bounce",
      "ttl": 3600,
      "pointsTo": "bounce.sendix.dev"
    },
    {
      "groupId": "tracking",
      "type": "CNAME",
      "host": "click",
      "ttl": 3600,
      "pointsTo": "track.sendix.dev"
    }
  ]
}
