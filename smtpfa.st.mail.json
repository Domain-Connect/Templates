{
  "providerId": "smtpfa.st",
  "providerName": "SMTPfast",
  "serviceId": "mail",
  "serviceName": "SMTPfast Email",
  "version": 1,
  "logoUrl": "https://smtpfa.st/logo.png",
  "description": "Configures DKIM, SPF, DMARC, and the MAIL FROM subdomain for sending email through SMTPfast.",
  "variableDescription": "dkim1, dkim2, dkim3: DKIM signing tokens generated by AWS SES during domain verification. region: AWS SES region (e.g. eu-west-2). spfDomain: subdomain used for the bounce / MAIL FROM (typically 'bounce').",
  "syncPubKeyDomain": "smtpfa.st",
  "syncRedirectDomain": "smtpfa.st",
  "syncBlock": false,
  "records": [
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim1%._domainkey",
      "pointsTo": "%dkim1%.dkim.amazonses.com",
      "ttl": 1800
    },
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim2%._domainkey",
      "pointsTo": "%dkim2%.dkim.amazonses.com",
      "ttl": 1800
    },
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim3%._domainkey",
      "pointsTo": "%dkim3%.dkim.amazonses.com",
      "ttl": 1800
    },
    {
      "groupId": "outbound",
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:amazonses.com"
    },
    {
      "groupId": "outbound",
      "type": "MX",
      "host": "%spfDomain%",
      "pointsTo": "feedback-smtp.%region%.amazonses.com",
      "priority": 10,
      "ttl": 3600
    },
    {
      "groupId": "outbound",
      "type": "SPFM",
      "host": "%spfDomain%",
      "spfRules": "include:amazonses.com"
    },
    {
      "groupId": "dmarc",
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=none; adkim=r; aspf=r; rua=mailto:postmaster@%domain%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DMARC1",
      "essential": "OnApply"
    }
  ]
}
