{
    "providerId": "forgigs.com",
    "providerName": "Forgigs",
    "serviceId": "connect-subdomain",
    "serviceName": "Connect your subdomain to Forgigs",
    "version": 1,
    "logoUrl": "https://pages.forgigs.com/logo.svg",
    "description": "Sets up DNS records to connect your subdomain to Forgigs for both page routing and email sending. Creates a CNAME record at the subdomain for routing, a DKIM TXT record, an SPF record, and an MX record for email authentication.",
    "variableDescription": "%vercel_cname%: Forgigs CNAME target; %dkim_value%: DKIM public key for email authentication",
    "syncPubKeyDomain": "keys.forgigs.com",
    "syncRedirectDomain": "pages.forgigs.com",
    "hostRequired": true,
    "records": [
        {
            "type": "CNAME",
            "host": "@",
            "pointsTo": "%vercel_cname%",
            "ttl": 3600
        },
        {
            "type": "TXT",
            "host": "resend._domainkey",
            "data": "%dkim_value%",
            "ttl": 3600
        },
        {
            "type": "MX",
            "host": "send",
            "pointsTo": "feedback-smtp.eu-west-1.amazonses.com",
            "priority": 10,
            "ttl": 3600
        },
        {
            "type": "SPFM",
            "host": "send",
            "spfRules": "include:amazonses.com",
            "ttl": 3600
        }
    ]
}
