{
    "providerId": "monpetitbistro.com",
    "providerName": "MonPetitBistro",
    "serviceId": "website",
    "serviceName": "MonPetitBistro - Website",
    "version": 1,
    "description": "Connects your domain name to the website you have created on MonPetitBistro",
    "variableDescription": "target: The target hostname for the website (e.g. fallback.monpetitbist.ro)",
    "hostRequired": false,
    "syncPubKeyDomain": "monpetitbistro.com",
    "syncRedirectDomain": "monpetitbistro.com",
    "records": [
        {
            "type": "APEXCNAME",
            "host": "@",
            "pointsTo": "%target%",
            "ttl": 3600
        },
        {
            "type": "CNAME",
            "host": "www",
            "pointsTo": "@",
            "ttl": 3600
        }
    ]
}