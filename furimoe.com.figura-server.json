{
  "providerId": "furimoe.com",
  "providerName": "Furimoe",
  "serviceId": "figura-server",
  "serviceName": "Furimoe Figura Server",
  "version": 1,
  "logoUrl": "https://cdn.masuru.in.th/storage/furimoe/furimoe-logo-2x1.webp",
  "description": "Connects a domain to a Furimoe Figura server and verifies domain ownership in one step",
  "variableDescription": "host: subdomain or @ for root, target: CNAME target for the Figura backend server, verifytxt: verification token issued by Furimoe",
  "syncPubKeyDomain": "furimoe.com",
  "syncRedirectDomain": "static.furimoe.com",
  "hostRequired": true,
  "records": [
    {
      "groupId": "figura",
      "type": "CNAME",
      "host": "%host%",
      "pointsTo": "%target%",
      "ttl": 3600
    },
    {
      "groupId": "verify",
      "type": "TXT",
      "host": "_furimoe-challenge",
      "data": "token=%verifytxt%",
      "ttl": 3600
    }
  ]
}
