{
  "providerId": "brixus365.com",
  "providerName": "Brixus365",
  "serviceId": "emailauth",
  "serviceName": "Email Authentication",
  "version": 2,
  "logoUrl": "https://brixus365.com/favicon.svg",
  "description": "Configure DKIM, SPF, DMARC, and domain ownership verification records for sending email via Brixus365.",
  "variableDescription": "dkim1, dkim2, dkim3: DKIM signing tokens generated by Brixus365 during domain setup. verify: domain ownership verification token.",
  "syncPubKeyDomain": "brixus365.com",
  "syncRedirectDomain": "app.brixus365.com",
  "syncBlock": false,
  "records": [
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim1%._domainkey",
      "pointsTo": "%dkim1%.dkim.amazonses.com",
      "ttl": 1800
    },
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim2%._domainkey",
      "pointsTo": "%dkim2%.dkim.amazonses.com",
      "ttl": 1800
    },
    {
      "groupId": "dkim",
      "type": "CNAME",
      "host": "%dkim3%._domainkey",
      "pointsTo": "%dkim3%.dkim.amazonses.com",
      "ttl": 1800
    },
    {
      "groupId": "spf",
      "type": "SPFM",
      "host": "@",
      "spfRules": "include:amazonses.com"
    },
    {
      "groupId": "dmarc",
      "type": "TXT",
      "host": "_dmarc",
      "data": "v=DMARC1; p=none; adkim=r; aspf=r; rua=mailto:postmaster@%domain%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "v=DMARC1",
      "essential": "OnApply"
    },
    {
      "groupId": "verification",
      "type": "TXT",
      "host": "_brixus-verify",
      "data": "brixus-verify-%verify%",
      "ttl": 3600,
      "txtConflictMatchingMode": "Prefix",
      "txtConflictMatchingPrefix": "brixus-verify-"
    }
  ]
}
